@page "/ai"
@attribute [Authorize]
@rendermode InteractiveServer
@using SunroomCrm.Shared.DTOs.AI
@inject IAiService AiService
@inject ISnackbar Snackbar

<PageTitle>AI Panel — Sunroom CRM</PageTitle>

<PageHeader Title="AI Panel" Subtitle="Powered by AI to help you sell smarter" />

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--sunroom-gray-200); border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-3">Summarize Text</MudText>
            <MudTextField @bind-Value="_summarizeText" Label="Enter text to summarize" Variant="Variant.Outlined" Lines="4" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="Summarize"
                       Disabled="@(string.IsNullOrWhiteSpace(_summarizeText) || _summarizing)">
                @if (_summarizing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Summarize
            </MudButton>
            @if (!string.IsNullOrEmpty(_summaryResult) || _summarizing)
            {
                <MudAlert Severity="Severity.Info" Class="mt-3">
                    @_summaryResult
                    @if (_summarizing) { <span style="display:inline-block;width:2px;height:1em;background:var(--mud-palette-primary);margin-left:2px;vertical-align:text-bottom;animation:blink .8s step-end infinite;" /> }
                </MudAlert>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--sunroom-gray-200); border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-3">Smart Search</MudText>
            <MudTextField @bind-Value="_searchQuery" Label="Ask a question about your data" Variant="Variant.Outlined" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SmartSearch"
                       Disabled="@(string.IsNullOrWhiteSpace(_searchQuery) || _searching)">
                @if (_searching) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Search
            </MudButton>
            @if (!string.IsNullOrEmpty(_searchResult) || _searching)
            {
                <MudAlert Severity="Severity.Info" Class="mt-3">
                    @_searchResult
                    @if (_searching) { <span style="display:inline-block;width:2px;height:1em;background:var(--mud-palette-primary);margin-left:2px;vertical-align:text-bottom;animation:blink .8s step-end infinite;" /> }
                </MudAlert>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-4">
    <MudItem xs="12" md="6">
        <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--sunroom-gray-200); border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-3">Deal Insights</MudText>
            <MudTextField @bind-Value="_dealIdInput" Label="Enter Deal ID" Variant="Variant.Outlined" InputType="InputType.Number" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="GenerateDealInsights"
                       Disabled="@(_dealIdInput <= 0 || _generatingInsights)">
                @if (_generatingInsights) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Generate Insights
            </MudButton>
            @if (!string.IsNullOrEmpty(_insightsResult) || _generatingInsights)
            {
                <MudAlert Severity="Severity.Info" Class="mt-3">
                    @_insightsResult
                    @if (_generatingInsights) { <span style="display:inline-block;width:2px;height:1em;background:var(--mud-palette-primary);margin-left:2px;vertical-align:text-bottom;animation:blink .8s step-end infinite;" /> }
                </MudAlert>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private string? _summarizeText;
    private string? _summaryResult;
    private bool _summarizing;
    private string? _searchQuery;
    private string? _searchResult;
    private bool _searching;
    private int _dealIdInput;
    private string? _insightsResult;
    private bool _generatingInsights;

    private Timer? _renderTimer;

    private async Task Summarize()
    {
        _summarizing = true;
        _summaryResult = "";
        _renderTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, 0, 100);

        try
        {
            await foreach (var token in AiService.SummarizeStreamAsync(
                new SummarizeRequest { Text = _summarizeText! }))
            {
                _summaryResult += token;
            }
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally
        {
            _renderTimer?.Dispose();
            _summarizing = false;
            StateHasChanged();
        }
    }

    private async Task SmartSearch()
    {
        _searching = true;
        _searchResult = "";
        _renderTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, 0, 100);

        try
        {
            await foreach (var token in AiService.SmartSearchStreamAsync(_searchQuery!))
            {
                _searchResult += token;
            }
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally
        {
            _renderTimer?.Dispose();
            _searching = false;
            StateHasChanged();
        }
    }

    private async Task GenerateDealInsights()
    {
        _generatingInsights = true;
        _insightsResult = "";
        _renderTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, 0, 100);

        try
        {
            await foreach (var token in AiService.DealInsightsStreamAsync(_dealIdInput))
            {
                _insightsResult += token;
            }
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally
        {
            _renderTimer?.Dispose();
            _generatingInsights = false;
            StateHasChanged();
        }
    }
}
